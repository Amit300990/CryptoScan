# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/cryptoguard

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Credential Encryption ─────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of cloud credentials.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-hex-chars

# ── CORS (production only) ────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty when API and frontend
# are served from the same domain (single-service Railway deployment).
# ALLOWED_ORIGINS=https://your-app.up.railway.app

# ── Frontend dev server (local only) ─────────────────────────────────────────
# VITE_PORT=5173        # frontend dev server port (default: 5173)
# API_PORT=3000         # backend port proxied by Vite (default: 3000)
